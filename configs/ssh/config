Host *
    IdentityAgent ~/.1password/agent.sock

Host gitlab.com
    HostName gitlab.com
    User git
    IdentityFile ~/.ssh/personal-key.pub
    IdentitiesOnly yes

Host pergit
    HostName github.com
    User git
    IdentityFile ~/.ssh/personal-key.pub
    IdentitiesOnly yes

Host s4lgit
    HostName github.com
    User git
    IdentityFile ~/.ssh/s4l-key.pub
    IdentitiesOnly yes

Host 192.168.*
    User pepefrog
    IdentityFile ~/.ssh/personal-key.pub

